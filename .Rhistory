# 2. Simulação de Jogadores Visitando a Loja por Hora (rpois())
jogadores_visitas <- rpois(8, lambda = 30)
plot(jogadores_visitas, type = "h", lwd = 2,
main = "Visitas na Loja por Hora",
xlab = "Horas",
ylab = "Número de visitas",
xaxt = "n",
col = "black")
axis(1, at = 1:8, labels = paste(13:20, sep = "", ":00"))
points(jogadores_visitas, pch = 21, col = "red", bg = "white")
# 3. Simulação de Uso de Cupons Virtuais (rbinom())
jogadores_cupons <- rbinom(n = 500, 1, 0.45)
table(jogadores_cupons)
cupons_usados <- sum(jogadores_cupons == 1)
cupons_nao_usados <- sum(jogadores_cupons == 0)
total <- 500
print(total)
valores <- c(cupons_usados, cupons_nao_usados)
percentual_usados <- paste0((round((cupons_usados * 100) / total)), "%")
print(percentual_usados)
percentual_nao_usados <- paste0((round((cupons_nao_usados * 100) / total)), "%")
print(percentual_nao_usados)
percentual_total <- c(percentual_usados, percentual_nao_usados)
pie(valores, labels = percentual_total,
main = "Distribuição de Uso de Cupons Virtuais (%)",
col = c("#a8dadc", "#e63946"))
legend("bottomleft",
legend = c("Cupons usados", "Cupons não usados"),
col = c("#a8dadc", "#e63946"),
lwd = 5)
