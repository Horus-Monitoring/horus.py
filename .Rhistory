# Reproduzir sempre os mesmos valores aleatórios com set.seed()
# 111 pode ser qualquer numero inteiro (ponto de partida)
# usa uma vez no inicio do script!
set.seed(111)
# criando amostragem para a variável idade, utilizando a média das modelos de 24 anos
# e um desvio padrão igual a 2 (o que significa que 95% das modelos tem idade entre 20 anos e 26 anos)
# Variável Quantitativa Discreta
idade <- rnorm(n = 20, mean = 24, sd = 2)
idade <- round(idade)
modelos <- data.frame(idade=idade)
# criando amostragem para a variavel altura, utilizando a media de altura de 1,78m
# e um desvio padrão igual a 3 (o que significa que 95% das modelos tem altura entre 1,72m e 1,84m)
# Variável Quantitativa Contínua
altura <- rnorm(n = 20, mean = 178, sd = 3)
altura <- round(altura)
modelos$altura <- altura / 100 # altura em metros
# criando amostragem para a variavel peso, utilizando a media de peso de 56kg
# e um desvio padrão igual a 2 (o que significa que 95% das modelos tem peso entre 52kg e 60kg)
# Variável Quantitativa Contínua
peso <- rnorm(n = 20, mean = 56, sd = 2)
peso <- round(peso, 2)
modelos$peso <- peso
# criando variavel imc - Quantitativa Contínua
modelos$imc <- modelos$peso / modelos$altura^2
modelos$imc <- round(modelos$imc, 2)
# criando amostragem para a variavel salário anual, utilizando a media de salario anual de US$ 1.000.000
# e um desvio padrão igual a US$ 300.000 (o que significa que 95% das modelos tem salario anual entre
# US$ 400.000 e US$ 1.600.000)
# Variável Quantitativa Contínua
salario <- rnorm(n = 20, mean = 1000000, sd = 300000)
salario <- round(salario, 2)
modelos$salario <- salario
# sample serve para sortear valores aleatórios de um conjunto (opções que eu escolhi no caso!)
# Variável Qualitativa Nominal
nacionalidade <- sample(c("Brasil", "Estados Unidos", "Alemanha", "Itália", "França", "Inglaterra"),
20, replace = TRUE)
modelos$país <- nacionalidade
# Nos anos 90 e 2000, a industria da moda tinha uma cultura mais permissiva com cigarro,
# já que fumar era associado a controle de peso, além de estilo e estética. No caso, as
# modelos do Victoria's Secret geralmente presavam por uma imagem mais saudável, logo
# as chances de serem fumantes era menos provável mas não nula!
# Variável Binaria com 80% de chance de ser "Não" e 20% de chance de ser "Sim"
fumante <- sample(c("Não", "Sim"), 20, replace = TRUE, prob = c(0.8, 0.2))
modelos$fumante <- fumante
# Variável Quantitativa Discreta
carros <- sample(0:3, 20, replace = TRUE, prob = c(0.05, 0.6, 0.25, 0.10))
modelos$carros <- carros
# Variável Quantitativa Discreta
# Modelos jovens com foco na carreira
filhos <- sample(0:3, 20, replace = TRUE, prob = c(0.65, 0.20, 0.10, 0.05))
modelos$filhos <- filhos
# Variavel Qualitativa Ordinal
cargo <- sample(c("Angel", "Passarela", "Comercial", "Iniciante"), 20, replace = TRUE)
modelos$cargo <- cargo
# Variavel Qualitativa Nominal
nomes <- sample(
c("Gisele Bundchen",
"Adriana Lima",
"Alessandra Ambrosio",
"Heidi Klum",
"Tyra Banks",
"Karolina Kurkova",
"Izabel Goulart",
"Selita Ebanks",
"Marisa Miller",
"Miranda Kerr",
"Doutzen Kroes",
"Rosie Huntington-Whiteley",
"Candice Swanepoel",
"Erin Heatherton",
"Lindsay Ellingson",
"Behati Prinsloo",
"Ana Beatriz Barros",
"Isabeli Fontana",
"Raquel Zimmermann",
"Caroline Trentini"
), 20, replace = FALSE)
modelos$nome <- nomes
# Histograma da Idade das Modelos
hist(modelos$idade,
main = "Distribuição da Idade das Modelos",
col = "#FCBBDC",
xlab = "Idade",
ylab = "")
# Histograma da Altura das Modelos
hist(modelos$altura,
main = "Distribuição da Altura das Modelos",
col = "#0BA0DB",
xlab = "Altura(m)",
ylab = "")
# Histograma do Peso das Modelos
hist(modelos$peso,
main = "Distribuição do Peso das Modelos",
col = "#9AC964",
xlab = "Peso(Kg)",
ylab = "")
# Histograma do IMC das Modelos
hist(modelos$imc,
main = "Distribuição do IMC das Modelos",
col = "#E34A75",
xlab = "IMC",
ylab = "")
# Histograma do Salário das Modelos
hist(modelos$salario,
main = "Distribuição dos Salários Anuais das Modelos",
col = "#7672E9",
xlab = "Salário (em milhões US$)",
ylab = "",
xaxt = "n"
)
axis(1, at = seq(0, max(modelos$salario), length.out = 8),
labels = paste0(round(seq(0, max(modelos$salario), length.out = 8)/1e6, 1), "M"))
# Gráfico de barras da Nacionalidade das Modelos
table(modelos$país)
barplot(table(modelos$país),
main = "Relação Entre a Quantidade de Modelos e Seu País de Origem",
col = "#C8096C",
ylab = "Número de Modelos")
# Gráfico de barras do "Cargo" das Modelos
# factor para transformar uma variavel em categorica para poder ordenar de acordo com a hierarquia
modelos$cargo <- factor(modelos$cargo, levels = c("Iniciante", "Comercial", "Passarela", "Angel"))
table(modelos$cargo)
barplot(table(modelos$cargo),
main = "Distribuição do Tipo de Nível das Modelos",
col = "#BBE6FC",
ylab = "Número de Modelos")
# Gráfico de barras para comparar as modelos que fumam e as que não fumam
barplot(table(modelos$fumante),
main = "Distribuição de Modelos Fumantes",
col = "#FCF0BB",
xlab = "Fumantes",
ylab = "Número de Modelos")
# Gráfico de barras para comparar quantidade de carros das modelos
barplot(table(modelos$carros),
main = "Distribuição da Quantidade de Carros",
col = "#E0BBFC",
xlab = "Quantidade de Carros",
ylab = "Número de Modelos")
