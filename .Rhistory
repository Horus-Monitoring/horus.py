geom_point(color = "darkblue", size = 2) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Crescimento da Memória RAM Antes do Incidente",
x = "Tempo",
y = "RAM(%)"
) +
theme_gray()
